# Copiar a .env y completar los valores

# Seguridad
SECRET_KEY=cambia-esto-por-una-clave-secreta-larga-y-aleatoria
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,tu-dominio.railway.app

# Base de datos — opción 1: URL completa (Railway provee esto automáticamente)
DATABASE_URL=postgresql://usuario:contraseña@host:5432/nombre_db

# Base de datos — opción 2: variables individuales (usar si no hay DATABASE_URL)
# DB_NAME=upgwebsite
# DB_USER=postgres
# DB_PASSWORD=contraseña
# DB_HOST=localhost
# DB_PORT=5432

# CORS — orígenes permitidos (separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:5500
