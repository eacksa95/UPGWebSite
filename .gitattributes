# Normalizar fin de línea a LF en repositorio, checkout como nativo del SO
* text=auto

# Forzar LF para archivos de código
*.py    text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.toml  text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binarios — no tocar
*.png   binary
*.jpg   binary
*.ico   binary
*.woff2 binary
